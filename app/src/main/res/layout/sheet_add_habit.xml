<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/card"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:background="@color/border"/>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="새 퀘스트 등록"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/gold"
        android:layout_marginStart="22dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="20dp"/>

    <!-- Name input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginBottom="20dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_habit_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="습관 이름 (예: 물 2L 마시기)"
            android:maxLength="30"
            android:inputType="text"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Stat label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="스탯 선택"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/text_muted"
        android:letterSpacing="0.1"
        android:layout_marginStart="22dp"
        android:layout_marginBottom="10dp"/>

    <!-- Stat buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp">

        <LinearLayout android:id="@+id/btn_str" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="10dp" android:layout_marginEnd="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💪" android:textSize="18sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STR" android:textSize="10sp" android:textStyle="bold" android:textColor="#FFFF6B6B" android:gravity="center"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_int" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="10dp" android:layout_marginEnd="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🧠" android:textSize="18sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="INT" android:textSize="10sp" android:textStyle="bold" android:textColor="#FF60A5FA" android:gravity="center"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_vit" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="10dp" android:layout_marginEnd="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌿" android:textSize="18sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="VIT" android:textSize="10sp" android:textStyle="bold" android:textColor="#FF34D399" android:gravity="center"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_wil" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="10dp" android:layout_marginEnd="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔮" android:textSize="18sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WIL" android:textSize="10sp" android:textStyle="bold" android:textColor="#FFA78BFA" android:gravity="center"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_dex" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="10dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡" android:textSize="18sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DEX" android:textSize="10sp" android:textStyle="bold" android:textColor="#FFFBBF24" android:gravity="center"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp">

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="취소"
            android:layout_marginEnd="10dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btn_add"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="퀘스트 등록"
            android:textStyle="bold"/>
    </LinearLayout>
</LinearLayout>

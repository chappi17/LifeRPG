<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingTop="36dp">

        <!-- Character Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#FF1F1B3E"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Avatar -->
                    <FrameLayout
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:layout_marginEnd="16dp">

                        <TextView
                            android:id="@+id/tv_avatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="🧑"
                            android:textSize="36sp"
                            android:gravity="center"
                            android:background="@drawable/bg_avatar"/>

                        <TextView
                            android:id="@+id/tv_level"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|end"
                            android:text="Lv.1"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textColor="@color/bg"
                            android:background="@drawable/bg_level_badge"
                            android:paddingStart="6dp"
                            android:paddingEnd="6dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"/>
                    </FrameLayout>

                    <!-- Info -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_class_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="견습 모험가"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="@color/gold"
                            android:letterSpacing="0.1"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="나의 영웅"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:id="@+id/tv_class_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"/>

                        <TextView
                            android:id="@+id/tv_total_xp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/gold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- XP Bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:id="@+id/tv_xp_progress"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="@color/gold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="다음 레벨까지"
                            android:textSize="10sp"
                            android:textColor="@color/text_muted"/>
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/xp_bar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/xp_progress"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Titles Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎖 칭호"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/gold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:id="@+id/title_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="14dp"/>

        <!-- Stats Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚔️ 스탯"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/gold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="10dp"/>

        <android.widget.GridLayout
            android:id="@+id/stats_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginBottom="14dp"/>

        <!-- Skills Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌟 습관 스킬"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/gold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:id="@+id/skills_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="14dp"/>

        <!-- Achievements Section -->
        <TextView
            android:id="@+id/tv_ach_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏆 업적"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/gold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:id="@+id/ach_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
